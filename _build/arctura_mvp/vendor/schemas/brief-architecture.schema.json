{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://startup-building.local/schemas/brief-architecture.schema.json",
  "title": "Architecture Design Brief (P3 output)",
  "description": "Schema for P2 Architecture pipeline input. Covers multi-floor buildings: residences, office towers, hotels, civic, mixed-use, large sports/cultural venues.",

  "type": "object",
  "required": ["style"],
  "additionalProperties": true,

  "properties": {
    "project": {
      "description": "项目名。新 brief 用 string；允许 object 形式作历史兼容（arch-04 的旧格式）。",
      "oneOf": [
        { "type": "string", "minLength": 4 },
        { "type": "object" }
      ]
    },
    "slug": {
      "type": "string",
      "pattern": "^arch-[0-9]{2}-[a-z0-9-]+$",
      "description": "Architecture slug，形如 'arch-01-house'"
    },
    "client":        { "type": "string" },
    "building_type": {
      "type": "string",
      "description": "residential / office / hotel / civic / mixed-use / sports / cultural / retail / clinic / etc."
    },

    "site": {
      "type": "object",
      "properties": {
        "lot_size_m":   {
          "type": "object",
          "properties": { "length": { "type": "number" }, "width": { "type": "number" } }
        },
        "lot_area_sqm": { "type": "number", "exclusiveMinimum": 0 },
        "orientation":  { "type": "string", "description": "主入口朝向 / 主立面朝向" },
        "topography":   { "type": "string", "enum": ["平地", "缓坡", "陡坡", "不规则"] },
        "features":     { "type": "array", "items": { "type": "string" } }
      }
    },

    "building": {
      "type": "object",
      "properties": {
        "footprint_m": {
          "type": "object",
          "properties": { "length": { "type": "number" }, "width": { "type": "number" } }
        },
        "footprint_sqm":        { "type": "number", "exclusiveMinimum": 0 },
        "floors":               { "type": "integer", "minimum": 1, "maximum": 50 },
        "floor_heights_m":      {
          "type": "object",
          "description": "{F1: 3.0, F2: 3.0, ...}；特殊键如 roof_parapet / roof_truss 允许超出常规层高范围",
          "additionalProperties": {
            "oneOf": [
              { "type": "number", "minimum": 0, "maximum": 40 },
              { "type": "null" }
            ]
          }
        },
        "total_height_m":       { "type": "number", "exclusiveMinimum": 0 },
        "gross_floor_area_sqm": { "type": "number", "exclusiveMinimum": 0 },
        "far":                  { "type": "number", "minimum": 0, "maximum": 15 },
        "coverage_percent":     { "type": "number", "minimum": 0, "maximum": 100 }
      }
    },

    "style": {
      "description": "风格描述。新 brief 推荐用 object 形式；允许 string 形式作历史兼容。",
      "oneOf": [
        {
          "type": "object",
          "required": ["keywords"],
          "properties": {
            "keywords": {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 1,
              "maxItems": 6
            },
            "palette": {
              "type": "object",
              "additionalProperties": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" }
            },
            "reference": {
              "oneOf": [
                { "type": "array", "items": { "type": "string" } },
                { "type": "string" }
              ]
            },
            "reference_brands": { "type": "array", "items": { "type": "string" } }
          }
        },
        { "type": "string", "description": "历史遗留：自由文本风格描述（如 'Tech-Loft / Glass Curtain Wall'）" }
      ]
    },

    "program": {
      "description": "功能单元列表。支持两种格式：(a) 扁平 list of {name, area_m2, floor?}；(b) 按楼层分组的 object {F1: [...], F2: [...]}",
      "oneOf": [
        {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name":    { "type": "string" },
              "area_m2": { "type": "number", "minimum": 0 },
              "floor":   { "type": "string" },
              "qty":     { "type": "integer", "minimum": 1 }
            }
          }
        },
        {
          "type": "object",
          "description": "按 floor 分组：{F1: [...], F2: [...], roof: [...]}；每项可为 object 或 string（历史遗留）",
          "patternProperties": {
            "^(F[0-9]+|roof|B[0-9]+)$": {
              "type": "array",
              "items": {
                "oneOf": [
                  {
                    "type": "object",
                    "required": ["name"],
                    "properties": {
                      "name":    { "type": "string" },
                      "area_m2": { "type": "number", "minimum": 0 }
                    }
                  },
                  { "type": "string" }
                ]
              }
            }
          }
        }
      ]
    },

    "structure":  { "type": "object", "description": "结构类型、材料、跨度等" },

    "envelope": {
      "type": "object",
      "description": "围护体系 · 主要用于 P8 合规检查。U 值 / SHGC 可选，compliance 从 IFC 优先提取。",
      "properties": {
        "wall_u":      { "type": "number", "description": "外墙传热系数 W/m²·K" },
        "roof_u":      { "type": "number", "description": "屋顶传热系数 W/m²·K" },
        "window_u":    { "type": "number", "description": "窗传热系数 W/m²·K" },
        "window_shgc": { "type": "number", "description": "窗太阳辐射得热系数" }
      }
    },

    "openings": {
      "type": "object",
      "description": "门窗开口 · 主要用于 WWR 分档检查（HK/CN/ASHRAE 各档不同限值）",
      "properties": {
        "wwr": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Window-to-Wall Ratio 窗墙比 0.0-1.0。HK BEC 按 <0.4 / 0.4-0.7 / >0.7 三档；CN 按 <0.5 / 0.5-0.7 分档"
        }
      }
    },

    "mep_brief": {
      "type": "object",
      "description": "MEP 简要 · 主要用于 P8 合规分档检查（HK 7.5/40/200 kW · ASHRAE 65/132/528 kW 等）",
      "properties": {
        "hvac_type":    { "type": "string", "description": "HVAC 系统类型（VRV/chiller/split/ideal_loads）" },
        "cooling_capacity_kw": {
          "type": "number",
          "minimum": 0,
          "description": "冷源额定容量 kW。HK BEC 7.5/40/200 kW 三档 COP 不同；ASHRAE/CN 类似分档"
        },
        "equipment_subtype": {
          "type": "string",
          "description": "设备子类（air-cooled / water-cooled / heat-pump / ...），用于 COP/EER 查表"
        }
      }
    },

    "budget_rmb":      { "type": "number", "minimum": 0 },
    "budget_hkd":      { "type": "number", "minimum": 0 },
    "timeline_months": { "type": "number", "exclusiveMinimum": 0, "maximum": 60 },
    "timeline_weeks":  { "type": "number", "exclusiveMinimum": 0 },

    "must_have": {
      "type": "array",
      "items": { "type": "string" }
    },

    "compliance": {
      "type": "object",
      "properties": {
        "target_code":      { "type": "string", "enum": ["HK", "CN_HOT", "CN_COLD", "ASHRAE", "JP"] },
        "primary_concerns": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
