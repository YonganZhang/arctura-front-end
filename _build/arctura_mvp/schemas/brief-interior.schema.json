{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://startup-building.local/schemas/brief-interior.schema.json",
  "title": "Interior Design Brief (P3 output)",
  "description": "Schema for P1 Interior Design pipeline input. Produced by P3 Brief Intake (via cli-anything-llm-intake) or hand-crafted. Covers room/shop fit-out scenarios (single room, single-floor commercial).",

  "type": "object",
  "required": ["project", "style"],
  "additionalProperties": true,

  "properties": {
    "project": {
      "type": "string",
      "description": "中文 + 可选英文副题的项目名，例如 '独立精品咖啡店 Coffee Lab · v1'",
      "minLength": 4
    },
    "slug": {
      "type": "string",
      "pattern": "^[0-9]{2}-[a-z0-9-]+$",
      "description": "文件夹 slug，形如 '14-central-japanese-coffee-bakery'"
    },
    "client": {
      "type": "string",
      "description": "客户类型/画像的一句话描述"
    },
    "business_model": {
      "type": "string",
      "description": "商业模式一句话（营业时间 / 主打品类 / 客群分时间）"
    },

    "space": {
      "type": "object",
      "properties": {
        "type":      { "type": "string", "description": "空间类型，如 '临街商铺改造' / '二楼商铺' / '住宅改造'" },
        "area_sqm":  { "type": "number", "exclusiveMinimum": 0, "maximum": 500, "description": "室内设计通常 ≤500 m²" },
        "n_floors":  { "type": "integer", "minimum": 1, "maximum": 3, "default": 1 },
        "dimensions_m": {
          "type": "object",
          "properties": {
            "length": { "type": "number", "exclusiveMinimum": 0 },
            "width":  { "type": "number", "exclusiveMinimum": 0 },
            "height": { "type": "number", "minimum": 2.4, "maximum": 6.0 }
          }
        },
        "frontage_m":         { "type": "number", "minimum": 0 },
        "existing_condition": { "type": "string" }
      }
    },

    "style": {
      "type": "object",
      "required": ["keywords"],
      "properties": {
        "keywords": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "maxItems": 6,
          "description": "3-5 个风格关键词，可中英混合。例 ['japandi-warm', 'timber-natural']"
        },
        "palette": {
          "type": "object",
          "description": "色彩调色板，key 为色名，value 为 hex。至少 3 个色",
          "additionalProperties": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" }
        },
        "reference_brands": {
          "type": "array",
          "items": { "type": "string" },
          "description": "风格参考品牌，如 ['% Arabica', 'Blue Bottle']"
        }
      }
    },

    "functional_zones": {
      "type": "array",
      "description": "功能分区列表。每个 zone 至少 name；area_m2 可为 0（书架墙等薄区）。",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name":        { "type": "string" },
          "area_m2":     { "type": "number", "minimum": 0 },
          "key_objects": { "type": "array", "items": { "type": "string" } }
        }
      }
    },

    "lighting": {
      "type": "object",
      "description": "照明需求，general / feature / daylight 三层"
    },

    "budget_rmb":     { "type": "number", "minimum": 0, "description": "预算（人民币，可选）" },
    "budget_hkd":     { "type": "number", "minimum": 0, "description": "预算（港币，可选，至少 rmb/hkd 有一个）" },
    "timeline_weeks": { "type": "number", "exclusiveMinimum": 0, "maximum": 52, "description": "工期（周）。室内设计通常 2-16 周。" },

    "must_have": {
      "type": "array",
      "items": { "type": "string" },
      "description": "硬性需求清单，每条一句话"
    },

    "envelope": {
      "type": "object",
      "description": "围护体系 · 主要用于 P8 合规检查。U 值 / SHGC 可选，compliance 从 IFC 优先提取。",
      "properties": {
        "wall_u":      { "type": "number", "description": "外墙传热系数 W/m²·K" },
        "roof_u":      { "type": "number", "description": "屋顶传热系数 W/m²·K" },
        "window_u":    { "type": "number", "description": "窗传热系数 W/m²·K" },
        "window_shgc": { "type": "number", "description": "窗太阳辐射得热系数" }
      }
    },

    "openings": {
      "type": "object",
      "description": "门窗开口 · 主要用于 WWR 分档检查（HK/CN/ASHRAE 各档不同限值）",
      "properties": {
        "wwr": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Window-to-Wall Ratio 窗墙比 0.0-1.0。HK BEC 按 <0.4 / 0.4-0.7 / >0.7 三档；CN 按 <0.5 / 0.5-0.7 分档"
        }
      }
    },

    "mep_brief": {
      "type": "object",
      "description": "MEP 简要 · 主要用于 P8 合规分档检查（HK 7.5/40/200 kW · ASHRAE 65/132/528 kW 等）",
      "properties": {
        "hvac_type":    { "type": "string", "description": "HVAC 系统类型（VRV/chiller/split/ideal_loads）" },
        "cooling_capacity_kw": {
          "type": "number",
          "minimum": 0,
          "description": "冷源额定容量 kW。HK BEC 7.5/40/200 kW 三档 COP 不同；ASHRAE/CN 类似分档"
        },
        "equipment_subtype": {
          "type": "string",
          "description": "设备子类（air-cooled / water-cooled / heat-pump / ...），用于 COP/EER 查表"
        }
      }
    },

    "compliance": {
      "type": "object",
      "properties": {
        "target_code":      { "type": "string", "enum": ["HK", "CN_HOT", "CN_COLD", "ASHRAE", "JP"] },
        "primary_concerns": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
