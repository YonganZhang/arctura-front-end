{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "framework": null,
  "outputDirectory": ".",
  "buildCommand": "echo 'static site · no build'",
  "installCommand": "echo 'no install needed'",
  "rewrites": [
    { "source": "/project/:slug([^/]+)", "destination": "/project" },
    { "source": "/project/:slug([^/]+)/", "destination": "/project" }
  ],
  "redirects": [
    { "source": "/Arctura Labs", "destination": "/", "permanent": true },
    { "source": "/Arctura Labs v1", "destination": "/v1", "permanent": true },
    { "source": "/Project Space", "destination": "/project", "permanent": true }
  ]
}
